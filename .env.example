# ── Application ──────────────────────────────────────────
ADIP_APP__NAME=ADIP
ADIP_APP__ENVIRONMENT=local
ADIP_APP__DEBUG=false

# ── API ──────────────────────────────────────────────────
ADIP_API__HOST=0.0.0.0
ADIP_API__PORT=8000
ADIP_API__PREFIX=/api/v1
ADIP_API__CORS_ORIGINS=["*"]

# ── Database (PostgreSQL) ───────────────────────────────
ADIP_DATABASE__DSN=postgresql+asyncpg://adip:change-me@postgres:5432/adip
ADIP_DATABASE__POOL_SIZE=10
ADIP_DATABASE__MAX_OVERFLOW=20
ADIP_DATABASE__POOL_RECYCLE=3600
ADIP_DATABASE__ECHO=false
ADIP_DATABASE__MIGRATE=true

# ── Redis ───────────────────────────────────────────────
ADIP_REDIS__DSN=redis://redis:6379/0
ADIP_REDIS__SOCKET_TIMEOUT=5
ADIP_REDIS__RETRY_ON_TIMEOUT=true

# ── ChromaDB ────────────────────────────────────────────
ADIP_CHROMA__HOST=chromadb
ADIP_CHROMA__PORT=8000
ADIP_CHROMA__COLLECTION_NAME=adip_embeddings
ADIP_CHROMA__EMBEDDING_DIMENSION=1536

# ── LLM ─────────────────────────────────────────────────
ADIP_LLM__PROVIDER=openai
ADIP_LLM__API_KEY=sk-placeholder
ADIP_LLM__MODEL=gpt-4
ADIP_LLM__TEMPERATURE=0.7
ADIP_LLM__MAX_TOKENS=4096
ADIP_LLM__TIMEOUT=60

# ── Security ────────────────────────────────────────────
ADIP_SECURITY__SECRET_KEY=change-me-to-a-long-random-string
ADIP_SECURITY__ALGORITHM=HS256
ADIP_SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=30
ADIP_SECURITY__REFRESH_TOKEN_EXPIRE_DAYS=7
ADIP_SECURITY__ALLOWED_HOSTS=["*"]

# ── Logging ─────────────────────────────────────────────
ADIP_LOGGING__LEVEL=INFO
ADIP_LOGGING__FORMAT=json
ADIP_LOGGING__INCLUDE_MODULE=true
ADIP_LOGGING__FILE_PATH=logs/adip.log
ADIP_LOGGING__FILE_MAX_BYTES=10485760
ADIP_LOGGING__FILE_BACKUP_COUNT=5
ADIP_LOGGING__OTEL_ENABLED=false
# ADIP_LOGGING__OTEL_ENDPOINT=http://otel-collector:4317
